---
import Layout from '../layouts/Layout.astro';
import generale from '../content/impostazioni/generale.json';
---
<Layout title="Contatti" description="Contatta Vivi Insubria per informazioni sulle gite o per iscriverti alla newsletter">
<style>
  .page-header { background: var(--verde); color: white; padding: 3rem 1.5rem; text-align: center; }
  .page-header h1 { font-family: var(--font-display); font-size: 2rem; font-weight: 600; }
  .page-header p { opacity: 0.85; margin-top: 0.4rem; }

  .content { max-width: 900px; margin: 3rem auto; padding: 0 1.5rem 4rem; }
  .layout { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }
  @media (max-width: 680px) { .layout { grid-template-columns: 1fr; } }

  .info h2 { font-family: var(--font-display); font-size: 1.3rem; color: var(--verde); margin-bottom: 1rem; }
  .info-item { display: flex; align-items: flex-start; gap: 0.75rem; margin-bottom: 1.25rem; }
  .info-icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 0.1rem; }
  .info-label { font-size: 0.78rem; color: var(--testo-muted); text-transform: uppercase; letter-spacing: 0.05em; }
  .info-val { font-weight: 500; color: var(--testo); }
  .info-val a { color: var(--lago); text-decoration: none; }

  .form-card {
    background: white;
    border: 1px solid var(--bordo);
    border-radius: 14px;
    padding: 1.75rem;
  }
  .form-card h2 { font-family: var(--font-display); font-size: 1.3rem; color: var(--verde); margin-bottom: 1.25rem; }

  .form-group { margin-bottom: 1.1rem; }
  .form-group label { display: block; font-size: 0.85rem; font-weight: 500; color: var(--testo); margin-bottom: 0.35rem; }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--bordo);
    border-radius: 8px;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--testo);
    background: white;
    transition: border-color 0.15s;
    outline: none;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus { border-color: var(--verde); }
  .form-group textarea { resize: vertical; min-height: 110px; }

  .btn-invia {
    width: 100%;
    background: var(--verde);
    color: white;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.85rem;
    border: none;
    border-radius: 9px;
    cursor: pointer;
    transition: background 0.15s;
    margin-top: 0.25rem;
  }
  .btn-invia:hover { background: var(--verde-chiaro); }

  .nota { font-size: 0.78rem; color: var(--testo-muted); margin-top: 0.75rem; text-align: center; }

  .success-msg {
    display: none;
    background: var(--verde-pale);
    border: 1px solid #C6E0A8;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    font-size: 0.9rem;
    color: var(--verde);
    margin-top: 1rem;
    text-align: center;
  }
</style>

<div class="page-header">
  <h1>Contatti</h1>
  <p>Hai domande su una gita? Vuoi restare aggiornato? Scrivimi.</p>
</div>

<div class="content">
  <div class="layout">
    <div class="info">
      <h2>Come raggiungermi</h2>

      <div class="info-item">
        <div class="info-icon">📧</div>
        <div>
          <div class="info-label">Email</div>
          <div class="info-val"><a href={`mailto:${generale.email}`}>{generale.email}</a></div>
        </div>
      </div>

      {generale.telefono && (
        <div class="info-item">
          <div class="info-icon">💬</div>
          <div>
            <div class="info-label">WhatsApp</div>
            <div class="info-val"><a href={`https://wa.me/${generale.telefono.replace(/\D/g,'')}`}>{generale.telefono}</a></div>
          </div>
        </div>
      )}

      {generale.instagram && (
        <div class="info-item">
          <div class="info-icon">📸</div>
          <div>
            <div class="info-label">Instagram</div>
            <div class="info-val"><a href={generale.instagram} target="_blank" rel="noopener">@viviinsubria</a></div>
          </div>
        </div>
      )}

      <div class="info-item" style="margin-top: 2rem;">
        <div class="info-icon">⏰</div>
        <div>
          <div class="info-label">Tempi di risposta</div>
          <div class="info-val">Di solito rispondo entro 24-48 ore</div>
        </div>
      </div>

      <div class="info-item">
        <div class="info-icon">📍</div>
        <div>
          <div class="info-label">Territorio</div>
          <div class="info-val">Insubria — Lombardia e Canton Ticino</div>
        </div>
      </div>
    </div>

    <div>
      <div class="form-card">
        <h2>Scrivimi</h2>
        <form name="contatto" method="POST" data-netlify="true" netlify-honeypot="bot-field" id="contactForm">
          <input type="hidden" name="form-name" value="contatto" />
          <p style="display:none;"><input name="bot-field" /></p>

          <div class="form-group">
            <label for="nome">Nome e cognome *</label>
            <input type="text" id="nome" name="nome" required placeholder="Mario Rossi" />
          </div>

          <div class="form-group">
            <label for="email">Email *</label>
            <input type="email" id="email" name="email" required placeholder="mario@esempio.it" />
          </div>

          <div class="form-group">
            <label for="oggetto">Oggetto</label>
            <select id="oggetto" name="oggetto">
              <option value="Info gita">Informazioni su una gita</option>
              <option value="Prenotazione">Prenotazione</option>
              <option value="Newsletter">Iscrivimi alla newsletter</option>
              <option value="Altro">Altro</option>
            </select>
          </div>

          <div class="form-group">
            <label for="messaggio">Messaggio</label>
            <textarea id="messaggio" name="messaggio" placeholder="Scrivi qui la tua domanda..."></textarea>
          </div>

          <div class="form-group" style="display: flex; align-items: flex-start; gap: 0.5rem;">
            <input type="checkbox" id="privacy" name="privacy" required style="width: auto; margin-top: 3px;" />
            <label for="privacy" style="font-size: 0.8rem; color: var(--testo-muted); cursor: pointer;">
              Acconsento al trattamento dei dati personali per rispondere alla mia richiesta
            </label>
          </div>

          <button type="submit" class="btn-invia">Invia messaggio →</button>
          <p class="nota">I tuoi dati non vengono ceduti a terzi</p>
        </form>
        <div class="success-msg" id="successMsg">
          ✅ Messaggio inviato! Ti risponderò entro 24-48 ore.
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const form = document.getElementById('contactForm');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      await fetch('/', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: new URLSearchParams(data).toString() });
      form.style.display = 'none';
      document.getElementById('successMsg').style.display = 'block';
    });
  }
</script>
</Layout>
