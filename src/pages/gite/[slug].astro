---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const gite = await getCollection('gite');
  return gite.filter(g => g.data.published).map(gita => ({
    params: { slug: gita.slug },
    props: { gita },
  }));
}

const { gita } = Astro.props;
const { Content } = await gita.render();

function formatData(d) {
  if (!d) return null;
  return new Date(d).toLocaleDateString('it-IT', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
}
---
<Layout title={gita.data.title} description={`${gita.data.title} — Gita organizzata da Vivi Insubria. ${gita.data.prezzo}€ a persona.`}>
<style>
  .hero-gita {
    height: 340px;
    background: var(--verde-pale);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
    overflow: hidden;
    position: relative;
  }
  .hero-gita img { width: 100%; height: 100%; object-fit: cover; }
  .hero-gita-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 60%);
  }

  .page { max-width: 820px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

  .breadcrumb { font-size: 0.82rem; color: var(--testo-muted); margin-bottom: 1.5rem; }
  .breadcrumb a { color: var(--lago); text-decoration: none; }

  .badges { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .badge { font-size: 0.78rem; font-weight: 600; padding: 0.25rem 0.75rem; border-radius: 20px; }
  .badge-diff { background: var(--verde-pale); color: var(--verde-chiaro); }
  .badge-data { background: var(--lago-pale); color: var(--lago); }

  h1 { font-family: var(--font-display); font-size: clamp(1.6rem, 4vw, 2.2rem); color: var(--testo); margin-bottom: 1.5rem; line-height: 1.25; }

  .layout { display: grid; grid-template-columns: 1fr 320px; gap: 2.5rem; align-items: start; }
  @media (max-width: 720px) { .layout { grid-template-columns: 1fr; } }

  /* COLONNA SINISTRA */
  .meta-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    background: var(--crema);
    border: 1px solid var(--bordo);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin-bottom: 1.75rem;
    font-size: 0.875rem;
  }
  .meta-item { display: flex; align-items: center; gap: 0.4rem; color: var(--testo-muted); }
  .meta-item strong { color: var(--testo); }

  .incluso-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem 1rem; margin: 1rem 0 1.75rem; }
  @media (max-width: 500px) { .incluso-grid { grid-template-columns: 1fr; } }
  .incluso-item { font-size: 0.875rem; display: flex; align-items: flex-start; gap: 0.4rem; }
  .incluso-item.no { opacity: 0.6; text-decoration: line-through; }

  .prose h2 { font-family: var(--font-display); font-size: 1.2rem; color: var(--verde); margin: 1.75rem 0 0.6rem; }
  .prose p { color: var(--testo-muted); margin-bottom: 0.75rem; line-height: 1.7; font-size: 0.95rem; }
  .prose ul { padding-left: 1.25rem; color: var(--testo-muted); font-size: 0.95rem; }
  .prose li { margin-bottom: 0.3rem; }

  /* SIDEBAR PRENOTAZIONE */
  .sidebar-card {
    background: white;
    border: 1px solid var(--bordo);
    border-radius: 14px;
    padding: 1.5rem;
    position: sticky;
    top: 80px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
  }
  .prezzo-big { font-size: 2rem; font-weight: 700; color: var(--verde); }
  .prezzo-big span { font-size: 0.9rem; font-weight: 400; color: var(--testo-muted); }
  .divider { border: none; border-top: 1px solid var(--bordo); margin: 1rem 0; }
  .sidebar-row { display: flex; justify-content: space-between; font-size: 0.85rem; margin-bottom: 0.5rem; }
  .sidebar-row .label { color: var(--testo-muted); }
  .sidebar-row .val { font-weight: 500; }

  .btn-prenota {
    display: block;
    width: 100%;
    background: var(--verde);
    color: white;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.9rem;
    border-radius: 9px;
    text-align: center;
    text-decoration: none;
    margin-top: 1.25rem;
    transition: background 0.15s;
  }
  .btn-prenota:hover { background: var(--verde-chiaro); }
  .btn-contatta {
    display: block;
    width: 100%;
    border: 1px solid var(--bordo);
    color: var(--testo-muted);
    font-size: 0.875rem;
    padding: 0.7rem;
    border-radius: 9px;
    text-align: center;
    text-decoration: none;
    margin-top: 0.6rem;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-contatta:hover { border-color: var(--verde); color: var(--verde); }
  .sidebar-note { font-size: 0.78rem; color: var(--testo-muted); text-align: center; margin-top: 0.75rem; }
</style>

{gita.data.immagine && (
  <div class="hero-gita">
    <img src={gita.data.immagine} alt={gita.data.title} />
    <div class="hero-gita-overlay"></div>
  </div>
)}

<div class="page">
  <div class="breadcrumb">
    <a href="/">Home</a> › <a href="/gite">Gite</a> › {gita.data.title}
  </div>

  <div class="badges">
    <span class="badge badge-diff">{gita.data.difficolta}</span>
    {gita.data.data_evento && <span class="badge badge-data">{formatData(gita.data.data_evento)}</span>}
  </div>

  <h1>{gita.data.title}</h1>

  <div class="layout">
    <!-- COLONNA PRINCIPALE -->
    <div>
      <div class="meta-strip">
        <div class="meta-item">⏱ <strong>{gita.data.durata}</strong></div>
        <div class="meta-item">👥 Max <strong>{gita.data.posti} persone</strong></div>
        {gita.data.orario && <div class="meta-item">🕘 Ritrovo ore <strong>{gita.data.orario}</strong></div>}
        {gita.data.ritrovo && <div class="meta-item">📍 <strong>{gita.data.ritrovo}</strong></div>}
      </div>

      {(gita.data.incluso?.length > 0 || gita.data.non_incluso?.length > 0) && (
        <div>
          <h2 style="font-family: var(--font-display); font-size: 1.1rem; color: var(--verde); margin-bottom: 0.75rem;">Cosa è incluso</h2>
          <div class="incluso-grid">
            {gita.data.incluso?.map(v => <div class="incluso-item">✅ {v}</div>)}
            {gita.data.non_incluso?.map(v => <div class="incluso-item no">❌ {v}</div>)}
          </div>
        </div>
      )}

      <div class="prose">
        <Content />
      </div>
    </div>

    <!-- SIDEBAR -->
    <div>
      <div class="sidebar-card">
        <div class="prezzo-big">{gita.data.prezzo} € <span>/ persona</span></div>
        <hr class="divider" />
        <div class="sidebar-row">
          <span class="label">Durata</span>
          <span class="val">{gita.data.durata}</span>
        </div>
        <div class="sidebar-row">
          <span class="label">Difficoltà</span>
          <span class="val">{gita.data.difficolta}</span>
        </div>
        <div class="sidebar-row">
          <span class="label">Posti max</span>
          <span class="val">{gita.data.posti} partecipanti</span>
        </div>
        {gita.data.data_evento && (
          <div class="sidebar-row">
            <span class="label">Data</span>
            <span class="val">{formatData(gita.data.data_evento)}</span>
          </div>
        )}
        <a href="/contatti?gita=prenota" class="btn-prenota">Prenota il tuo posto →</a>
        <a href="/contatti" class="btn-contatta">Hai domande? Scrivimi</a>
        <p class="sidebar-note">Minimo 5 partecipanti per la conferma della gita</p>
      </div>
    </div>
  </div>
</div>
</Layout>
