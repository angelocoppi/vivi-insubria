---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Pagina non trovata">
<div style="text-align:center; padding: 6rem 1.5rem; max-width: 500px; margin: 0 auto;">
  <div style="font-size: 4rem; margin-bottom: 1rem;">🗺️</div>
  <h1 style="font-family: var(--font-display); color: var(--verde); font-size: 1.8rem; margin-bottom: 0.75rem;">Sentiero non trovato</h1>
  <p style="color: var(--testo-muted); margin-bottom: 1.5rem;">La pagina che cerchi non esiste o è stata spostata.</p>
  <a href="/" style="background: var(--verde); color: white; padding: 0.7rem 1.5rem; border-radius: 8px; text-decoration: none; font-weight: 500;">← Torna alla home</a>
</div>
</Layout>
