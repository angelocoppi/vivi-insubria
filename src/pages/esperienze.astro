---
import Layout from '../layouts/Layout.astro';
import pagine from '../content/impostazioni/pagine.json';

const key = Astro.url.pathname.replace('/', '').split('/')[0];
if (!pagine[key]) {
  return Astro.redirect('/');
}
---
<Layout title="Prossimamente">
<div style="text-align:center; padding: 5rem 1.5rem; max-width: 600px; margin: 0 auto;">
  <div style="font-size: 3rem; margin-bottom: 1rem;">🚧</div>
  <h1 style="font-family: var(--font-display); color: var(--verde); margin-bottom: 0.75rem;">Prossimamente</h1>
  <p style="color: var(--testo-muted);">Questa sezione è in arrivo. <a href="/contatti" style="color: var(--lago);">Iscriviti alla newsletter</a> per essere il primo a saperlo.</p>
  <a href="/" style="display:inline-block; margin-top: 1.5rem; background: var(--verde); color: white; padding: 0.65rem 1.5rem; border-radius: 8px; text-decoration: none; font-weight: 500;">← Torna alla home</a>
</div>
</Layout>
